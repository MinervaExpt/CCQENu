{
  "InputFiles":{
  "QElike":"/Users/schellma/Dropbox/ccqe/pub_run/pub_v18.root"
  },
  "Target":"Nucleons", // can be Protons, Neutrons or Nucleons
  "POTScale":1, //1 if you need to POT scale
  "Data_Cat":"data",
  "Signal_Cat":"qelike",
  "Background_Cat":["qelikenot"], // only use if doing Background stage

  "Samples": [
    "QElike"
  ],
  "Categories": [
    "data",
    "qelike",
    "qelikenot"
  ],
  "Data_Type": "reconstructed",
  "Signal_Type": "reconstructed",
  "Background_Type": "reconstructed",
  "Selected_Type":"selected_truth",
  "Truth_Type":"all_truth",
  "Migration_Type":"response",
  // these data_types below are used to load in the right set of histograms
  "data_types1D":{
    "data":["reconstructed"],
    "qelike":["reconstructed","selected_truth","all_truth","response_truth","response_reco"],
    "qelikenot": [
      "reconstructed"
    ]
  },
  "data_types2D":{
    "data":[],
    "qelike": ["response_migration"],
    "qelikenot": []
  },
  "Variables":["Q2QE","ptmu","pzmu"],
  "Scales":{"Q2QE":3,"ptmu":3,"pzmu":3},    // scale = logx + 2* logy
  "FluxNorm":{"Q2QE":false,"ptmu":false,"pzmu":false}, // true = do bin by bin
  "PixDir":"./pix",
  "LogMinimum":0.1,
  "Stages":{
    "Background":{"In":"reconstructed","Out":"bkgsub"},
    "Unfold":{"In":"bkgsub","Out":"unfolded"},
    "Efficiency":{"In":"unfolded","Out":"effcorr"},
    "Flux":{"In":"effcorr","Out":"sigma"}
  }
}
